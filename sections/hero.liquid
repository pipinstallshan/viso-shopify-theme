<style>
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 85% 10%, rgba(205, 162, 87, 0.25), transparent 28%),
      linear-gradient(135deg, #fff 0%, #f8f2e8 100%);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    min-height: clamp(620px, 82vh, 820px);
    padding-block: calc(var(--header-height) + 2rem) 4rem;
  }

  .hero__content {
    position: relative;
    z-index: 2;
  }

  .hero__badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.7rem;
    border: 1px solid rgba(17, 17, 17, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    color: #111;
    font-size: 0.78rem;
    font-weight: 850;
    box-shadow: 0 10px 26px rgba(17, 17, 17, 0.06);
  }

  .hero__title {
    margin-bottom: 1.25rem;
    max-width: 10ch;
  }

  .hero__title em {
    color: var(--color-gold);
    font-style: normal;
  }

  .hero__text {
    max-width: 560px;
    margin-bottom: 1.7rem;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 1.7vw, 1.2rem);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }

  .hero__proof {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    color: #111;
    font-size: 0.9rem;
    font-weight: 850;
  }

  .hero__stars {
    color: #f5b400;
    letter-spacing: 0.08em;
  }

  .hero__media {
    position: relative;
    min-height: 520px;
  }

  .hero__main-card {
    position: absolute;
    inset: 4% 8% 8% 2%;
    overflow: hidden;
    border: 10px solid #fff;
    border-radius: 34px;
    background: #f2ecdf;
    box-shadow: 0 34px 90px rgba(17, 17, 17, 0.18);
    transform: rotate(-2deg);
  }

  .hero__main-card img,
  .hero__main-card video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__main-card .placeholder-image {
    min-height: 100%;
  }

  .hero__floating-card {
    position: absolute;
    right: 0;
    bottom: 1rem;
    z-index: 2;
    width: min(260px, 42vw);
    padding: 1rem;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 24px;
    background: #fff;
    box-shadow: 0 22px 54px rgba(17, 17, 17, 0.16);
    animation: float 5s ease-in-out infinite;
  }

  .hero__floating-card strong {
    display: block;
    margin-bottom: 0.25rem;
    color: #111;
    font-size: 0.95rem;
  }

  .hero__floating-card span {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .hero__mini-product {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 0.8rem;
    align-items: center;
  }

  .hero__mini-image {
    overflow: hidden;
    width: 72px;
    height: 72px;
    border-radius: 18px;
    background: var(--color-surface);
  }

  @media (max-width: 989px) {
    .hero__inner {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: calc(var(--header-height) + 1.5rem);
    }

    .hero__media {
      min-height: 420px;
      order: -1;
    }

    .hero__main-card {
      inset: 0 5% 8% 0;
    }
  }

  @media (max-width: 749px) {
    .hero__media {
      min-height: 330px;
    }

    .hero__floating-card {
      width: min(245px, 76vw);
    }
  }
</style>

<section class="hero">
  <div class="page-width hero__inner">
    <div class="hero__content animate-on-scroll">
      <div class="hero__badge-row">
        <span class="hero__badge">Pakistan's premium sunglasses store</span>
        <span class="hero__badge">30 days money back</span>
      </div>

      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <h1 class="hero__title display-title">{{ section.settings.title }}</h1>

      {%- if section.settings.text != blank -%}
        <p class="hero__text">{{ section.settings.text }}</p>
      {%- endif -%}

      <div class="hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn btn--primary btn-arrow">{{ section.settings.button_label }}</a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="btn btn--secondary">{{ section.settings.button_label_2 }}</a>
        {%- endif -%}
      </div>

      <div class="hero__proof">
        <span class="hero__stars">★★★★★</span>
        <span>4.9/5 based on 230+ happy customers</span>
      </div>
    </div>

    <div class="hero__media animate-on-scroll">
      <div class="hero__main-card">
        {%- if section.settings.video != blank -%}
          {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
        {%- elsif section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', fetchpriority: 'high', alt: section.settings.title }}
        {%- else -%}
          <div class="placeholder-image">Hero Visual</div>
        {%- endif -%}
      </div>

      <div class="hero__floating-card">
        <div class="hero__mini-product">
          <div class="hero__mini-image">
            <div class="placeholder-image" style="min-height: 72px; font-size: 0.55rem;">Viso</div>
          </div>
          <div>
            <strong>{{ section.settings.float_title }}</strong>
            <span>{{ section.settings.float_text }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "video", "id": "video", "label": "Hero video" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New drops are live" },
    { "type": "html", "id": "title", "label": "Heading", "default": "Pakistan's <em>Premium</em> Sunglasses" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Standout frames, premium packaging, fast delivery, and styles made for Pakistani sun. Pick your look and wear it with confidence." },
    { "type": "text", "id": "button_label", "label": "Primary button", "default": "Shop Best Sellers" },
    { "type": "url", "id": "button_link", "label": "Primary link" },
    { "type": "text", "id": "button_label_2", "label": "Secondary button", "default": "New Arrivals" },
    { "type": "url", "id": "button_link_2", "label": "Secondary link" },
    { "type": "text", "id": "float_title", "label": "Floating card title", "default": "Seen on creators" },
    { "type": "text", "id": "float_text", "label": "Floating card text", "default": "Loved across Lahore, Karachi & Islamabad" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
