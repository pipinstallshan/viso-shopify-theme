<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .hero__media-col {
    position: relative;
    overflow: hidden;
  }

  .hero__media {
    position: absolute;
    inset: -10% 0 0 0;
    height: 120%;
    will-change: transform;
  }

  .hero__media img,
  .hero__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: kenBurns 20s ease-in-out infinite alternate;
  }

  .hero__media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(10,10,10,0.3) 0%, transparent 60%);
    z-index: 1;
  }

  .hero__content-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: calc(var(--header-height) + 3rem) var(--page-gutter) 4rem 4rem;
    background: var(--color-background);
    position: relative;
  }

  .hero__content-col::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, transparent, var(--color-gold), transparent);
    opacity: 0.4;
  }

  .hero__title {
    margin-bottom: 2rem;
    max-width: 14ch;
  }

  .hero__title em {
    font-style: italic;
    color: var(--color-gold);
    display: block;
  }

  .hero__text {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.85;
    margin-bottom: 3rem;
    max-width: 42ch;
    animation: fadeInUp 1s ease 0.3s forwards;
    opacity: 0;
  }

  .hero__actions {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    animation: fadeInUp 1s ease 0.5s forwards;
    opacity: 0;
  }

  .hero__meta {
    display: flex;
    gap: 3rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    animation: fadeInUp 1s ease 0.7s forwards;
    opacity: 0;
  }

  .hero__meta-item span {
    display: block;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .hero__meta-item strong {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-gold);
  }

  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    right: var(--page-gutter);
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-text-muted);
  }

  .hero__scroll-line {
    width: 60px;
    height: 1px;
    background: var(--color-gold);
    animation: lineGrow 1.5s ease 1s forwards;
    transform: scaleX(0);
    transform-origin: left;
  }

  @media (max-width: 989px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero__media-col {
      aspect-ratio: 4/5;
      min-height: 55vh;
    }

    .hero__content-col {
      padding: 3rem var(--page-gutter);
    }

    .hero__content-col::before { display: none; }

    .hero__scroll { display: none; }
  }
</style>

<section class="hero" data-hero-parallax>
  <div class="hero__media-col">
    <div class="hero__media" data-hero-media>
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
      {%- elsif section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', fetchpriority: 'high', alt: section.settings.title }}
      {%- else -%}
        <div style="width:100%;height:100%;background:linear-gradient(160deg,#0a0a0a 0%,#1a3d32 40%,#0f0f0f 100%);"></div>
      {%- endif -%}
    </div>
    <div class="hero__media-overlay"></div>
  </div>

  <div class="hero__content-col">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow eyebrow--line">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="hero__title display-title">{{ section.settings.title }}</h1>
    {%- if section.settings.text != blank -%}
      <p class="hero__text">{{ section.settings.text }}</p>
    {%- endif -%}
    <div class="hero__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--primary btn-arrow"><span>{{ section.settings.button_label }}</span></a>
      {%- endif -%}
      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="btn btn--ghost">{{ section.settings.button_label_2 }}</a>
      {%- endif -%}
    </div>

    <div class="hero__meta">
      <div class="hero__meta-item">
        <span>Craftsmanship</span>
        <strong>Italian Acetate</strong>
      </div>
      <div class="hero__meta-item">
        <span>Delivery</span>
        <strong>White Glove</strong>
      </div>
      <div class="hero__meta-item">
        <span>Origin</span>
        <strong>Lahore, PK</strong>
      </div>
    </div>
  </div>

  <div class="hero__scroll">
    <div class="hero__scroll-line"></div>
    <span>Discover</span>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video (overrides image)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Spring Summer 2026"
    },
    {
      "type": "html",
      "id": "title",
      "label": "Heading (use <em> for italic gold)",
      "default": "See the World <em>Differently</em>"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Curated eyewear for Pakistan's most discerning. Where Italian craftsmanship meets contemporary elegance — each frame a quiet statement of refinement."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button",
      "default": "Private Appointment"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
