<style>
  .cta-banner {
    position: relative;
    padding: clamp(4rem, 8vw, 7rem) 0;
    overflow: hidden;
    border-top: 1px solid rgba(17, 17, 17, 0.08);
    background: var(--color-surface);
  }

  .cta-banner__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 20%, rgba(212, 162, 76, 0.28) 0%, transparent 42%);
  }

  .cta-banner__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }

  .cta-banner__title {
    font-size: clamp(2.25rem, 5vw, 4rem);
    margin-bottom: 1.25rem;
    max-width: 16ch;
  }

  .cta-banner__text {
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 48ch;
    font-size: 1.0625rem;
  }

  @media (max-width: 749px) {
    .cta-banner__grid { grid-template-columns: 1fr; }
  }
</style>

<section class="cta-banner">
  <div class="cta-banner__bg"></div>
  <div class="page-width">
    <div class="cta-banner__grid animate-on-scroll">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow eyebrow--line">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="cta-banner__title">{{ section.settings.title }}</h2>
        {%- if section.settings.text != blank -%}
          <p class="cta-banner__text">{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--primary btn-arrow" style="white-space:nowrap;">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA banner",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Private Appointments" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Experience Viso In Person" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Book a private styling session at our Lahore flagship. Let our experts curate the perfect frame for your face and lifestyle." },
    { "type": "text", "id": "button_label", "label": "Button", "default": "Book Appointment" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "CTA banner" }]
}
{% endschema %}
