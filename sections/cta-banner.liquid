<style>
  .cta-banner {
    position: relative;
    padding: calc(var(--section-spacing) * 1.5) 0;
    text-align: center;
    overflow: hidden;
  }

  .cta-banner__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-background) 100%);
    z-index: 0;
  }

  .cta-banner__content {
    position: relative;
    z-index: 1;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-banner__title {
    margin-bottom: 1rem;
  }

  .cta-banner__text {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    line-height: 1.7;
  }
</style>

<section class="cta-banner">
  <div class="cta-banner__bg"></div>
  <div class="page-width">
    <div class="cta-banner__content animate-on-scroll">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="cta-banner__title">{{ section.settings.title }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="cta-banner__text">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--primary">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Private Appointments"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Experience Viso In Person"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Book a private styling session at our Lahore flagship. Let our experts curate the perfect frame for your face and lifestyle."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Book Appointment"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "CTA banner"
    }
  ]
}
{% endschema %}
