<style>
  .testimonials {
    padding: var(--section-spacing) 0;
    background: var(--color-background);
    border-top: 1px solid var(--color-border);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    padding: 3rem 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    position: relative;
    transition: border-color 0.5s ease, transform 0.5s ease;
  }

  .testimonial-card::before {
    content: '"';
    position: absolute;
    top: 1.5rem;
    left: 2rem;
    font-family: var(--font-heading);
    font-size: 4rem;
    line-height: 1;
    color: var(--color-gold);
    opacity: 0.3;
  }

  .testimonial-card:hover {
    border-color: rgba(201, 169, 98, 0.4);
    transform: translateY(-4px);
  }

  .testimonial-card__stars {
    color: var(--color-gold);
    margin-bottom: 1.75rem;
    letter-spacing: 0.3em;
    font-size: 0.75rem;
  }

  .testimonial-card__quote {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    line-height: 1.65;
    font-style: italic;
    margin-bottom: 2rem;
    padding-top: 1rem;
  }

  .testimonial-card__author {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
  }

  @media (max-width: 989px) {
    .testimonials__grid { grid-template-columns: 1fr; }
  }
</style>

<section class="testimonials">
  <div class="page-width">
    <div class="section-header section-header--center animate-on-scroll">
      <span class="eyebrow eyebrow--line">{{ section.settings.eyebrow }}</span>
      <h2 class="section-header__title">{{ section.settings.title }}</h2>
      <div class="divider divider--wide"></div>
    </div>

    <div class="testimonials__grid stagger-children">
      {%- for block in section.blocks -%}
        <div class="testimonial-card animate-on-scroll" {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial-card__quote">{{ block.settings.quote }}</p>
          <p class="testimonial-card__author">{{ block.settings.author }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Client Voices" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Trusted by the Discerning" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "The attention to detail is extraordinary. These aren't just sunglasses — they're a statement." },
        { "type": "text", "id": "author", "label": "Author", "default": "A.R., Lahore" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "The attention to detail is extraordinary. These aren't just sunglasses — they're a statement.", "author": "A.R., Lahore" } },
        { "type": "testimonial", "settings": { "quote": "Finally, eyewear that matches the calibre of my wardrobe. Viso understands luxury.", "author": "S.K., Karachi" } },
        { "type": "testimonial", "settings": { "quote": "The white-glove delivery experience alone sets Viso apart. Impeccable from start to finish.", "author": "F.H., Islamabad" } }
      ]
    }
  ]
}
{% endschema %}
