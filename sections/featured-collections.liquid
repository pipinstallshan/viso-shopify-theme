<style>
  .featured-collections {
    padding: var(--section-spacing) 0;
  }

  .featured-collections__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.25rem;
  }

  .collection-card:first-child {
    grid-row: span 2;
  }

  .collection-card {
    position: relative;
    overflow: hidden;
    min-height: 320px;
    display: block;
  }

  .collection-card:first-child {
    min-height: 100%;
  }

  .collection-card__media {
    position: absolute;
    inset: 0;
  }

  .collection-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .collection-card:hover .collection-card__media img {
    transform: scale(1.1);
  }

  .collection-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.9) 0%, rgba(10,10,10,0.1) 60%);
    z-index: 1;
    transition: background 0.5s ease;
  }

  .collection-card:hover .collection-card__overlay {
    background: linear-gradient(to top, rgba(10,10,10,0.95) 0%, rgba(26,61,50,0.3) 60%);
  }

  .collection-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem;
    z-index: 2;
  }

  .collection-card__count {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
  }

  .collection-card__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    margin-bottom: 1rem;
  }

  .collection-card__link-text {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.5s ease;
  }

  .collection-card:hover .collection-card__link-text {
    opacity: 1;
    transform: translateY(0);
    color: var(--color-gold);
  }

  @media (max-width: 989px) {
    .featured-collections__grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }
    .collection-card:first-child { grid-row: span 1; grid-column: span 2; min-height: 400px; }
  }

  @media (max-width: 749px) {
    .featured-collections__grid { grid-template-columns: 1fr; }
    .collection-card:first-child { grid-column: span 1; }
  }
</style>

<section class="featured-collections">
  <div class="page-width">
    <div class="section-header section-header--split animate-on-scroll">
      <div>
        <span class="eyebrow eyebrow--line">{{ section.settings.eyebrow }}</span>
        <h2 class="section-header__title">{{ section.settings.title }}</h2>
      </div>
      {%- if section.settings.text != blank -%}
        <p class="section-header__text">{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <div class="featured-collections__grid stagger-children">
      {%- for block in section.blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}
        <a href="{{ collection.url | default: '#' }}" class="collection-card animate-on-scroll luxury-frame" {{ block.shopify_attributes }}>
          <div class="collection-card__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- elsif collection.featured_image -%}
              {{ collection.featured_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: collection.title }}
            {%- else -%}
              <div class="placeholder-image" style="height:100%;">{{ block.settings.title | default: 'Collection' }}</div>
            {%- endif -%}
          </div>
          <div class="collection-card__overlay"></div>
          <div class="collection-card__content">
            {%- if collection.products_count -%}
              <p class="collection-card__count">{{ collection.products_count }} Pieces</p>
            {%- else -%}
              <p class="collection-card__count">Curated Selection</p>
            {%- endif -%}
            <h3 class="collection-card__title">{{ block.settings.title | default: collection.title | default: 'Collection' }}</h3>
            <span class="collection-card__link-text">Explore Collection →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collections",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated For You" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Signature Collections" },
    { "type": "textarea", "id": "text", "label": "Description", "default": "Each collection tells a story of precision, heritage, and uncompromising style." }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom image" },
        { "type": "text", "id": "title", "label": "Custom title" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collections",
      "blocks": [
        { "type": "collection", "settings": { "title": "The Aviator Edit" } },
        { "type": "collection", "settings": { "title": "Cat Eye" } },
        { "type": "collection", "settings": { "title": "Oversized" } }
      ]
    }
  ]
}
{% endschema %}
