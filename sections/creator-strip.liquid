<style>
  .creator-strip {
    padding: 2.2rem 0;
    background: #fff;
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
  }

  .creator-strip__header {
    margin-bottom: 1rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .creator-strip__grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .creator-strip__card {
    display: grid;
    place-items: center;
    min-height: 96px;
    padding: 1rem;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 20px;
    background: var(--color-surface);
    color: #111;
    text-align: center;
    font-weight: 900;
  }

  .creator-strip__avatar {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    margin-bottom: 0.55rem;
    border-radius: 999px;
    color: #fff;
    background: #111;
    font-size: 0.9rem;
  }

  @media (max-width: 989px) {
    .creator-strip__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (max-width: 749px) {
    .creator-strip__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
</style>

<section class="creator-strip">
  <div class="page-width">
    <p class="creator-strip__header">{{ section.settings.heading }}</p>
    <div class="creator-strip__grid">
      {%- for block in section.blocks -%}
        <div class="creator-strip__card" {{ block.shopify_attributes }}>
          <span class="creator-strip__avatar">{{ block.settings.name | slice: 0, 1 }}</span>
          {{ block.settings.name }}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Creator strip",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by creators, stylists and everyday legends" }
  ],
  "blocks": [
    {
      "type": "creator",
      "name": "Creator",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Creator Name" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Creator strip",
      "blocks": [
        { "type": "creator", "settings": { "name": "Irfan" } },
        { "type": "creator", "settings": { "name": "Daniyal" } },
        { "type": "creator", "settings": { "name": "Kashif" } },
        { "type": "creator", "settings": { "name": "Azlan" } },
        { "type": "creator", "settings": { "name": "Sana" } }
      ]
    }
  ]
}
{% endschema %}
