<style>
  .product-page { padding: 2rem 0 var(--section-spacing); }

  .product-page__grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .product-gallery { position: sticky; top: calc(var(--header-height) + 2rem); }

  .product-gallery__main {
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-surface);
    margin-bottom: 1.25rem;
    position: relative;
  }

  .product-gallery__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    cursor: zoom-in;
  }

  .product-gallery__main:hover img { transform: scale(1.04); }

  .product-gallery__thumbs {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .product-gallery__thumb {
    width: 72px;
    height: 72px;
    overflow: hidden;
    border: 1px solid transparent;
    cursor: pointer;
    transition: border-color var(--transition);
    background: var(--color-surface);
  }

  .product-gallery__thumb.is-active,
  .product-gallery__thumb:hover { border-color: var(--color-gold); }

  .product-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }

  .product-info { padding-top: 1rem; }

  .product-info__vendor {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }

  .product-info__title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .product-info__price {
    margin-bottom: 2.5rem;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .product-info__description {
    color: var(--color-text-muted);
    line-height: 1.85;
    margin-bottom: 2.5rem;
    font-size: 1.0625rem;
  }

  .product-info__actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .product-info__actions .btn { flex: 1; }

  .product-info__trust {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .product-info__trust-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  .product-info__trust-item svg { color: var(--color-gold); flex-shrink: 0; }

  @media (max-width: 989px) {
    .product-page__grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .product-gallery { position: static; }
  }
</style>

<section class="product-page" data-product-info>
  <div class="page-width">
    <nav class="breadcrumbs">
      <a href="/">Home</a><span>/</span>
      {%- if product.collections.first -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a><span>/</span>
      {%- endif -%}
      {{ product.title }}
    </nav>

    <div class="product-page__grid">
      <div class="product-gallery luxury-frame">
        <div class="product-gallery__main" id="ProductGallery-Main">
          {%- if product.featured_image -%}
            {{ product.featured_image | image_url: width: 1400 | image_tag: loading: 'eager', id: 'ProductGallery-Featured', alt: product.title }}
          {%- else -%}
            <div class="placeholder-image" style="height:100%;">Viso</div>
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for image in product.images -%}
              <button class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}" data-gallery-thumb="{{ image | image_url: width: 1400 }}" aria-label="View image {{ forloop.index }}">
                {{ image | image_url: width: 144 | image_tag: loading: 'lazy', alt: image.alt }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="product-info animate-on-scroll">
        {%- if product.vendor != blank -%}
          <p class="product-info__vendor">{{ product.vendor }}</p>
        {%- else -%}
          <p class="product-info__vendor">Viso Atelier</p>
        {%- endif -%}
        <h1 class="product-info__title">{{ product.title }}</h1>

        <div class="product-info__price" data-product-price>
          {% render 'price', product: product, price_class: 'price' %}
        </div>

        {%- if product.description != blank -%}
          <div class="product-info__description">{{ product.description }}</div>
        {%- endif -%}

        {% form 'product', product, data-product-form: '' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="variant-picker">
                <p class="variant-picker__label">{{ option.name }}</p>
                <div class="variant-picker__options">
                  {%- for value in option.values -%}
                    <div class="variant-picker__option">
                      <input type="radio" id="Option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}>
                      <label for="Option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}">{{ value }}</label>
                    </div>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <div class="product-info__actions">
            <div class="quantity-selector">
              <button type="button" data-quantity-minus aria-label="Decrease">−</button>
              <input type="number" name="quantity" value="1" min="1" aria-label="Quantity">
              <button type="button" data-quantity-plus aria-label="Increase">+</button>
            </div>
            <button type="submit" class="btn btn--primary btn-arrow" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %} data-add-text="{{ 'products.product.add_to_cart' | t }}" data-sold-out-text="{{ 'products.product.sold_out' | t }}">
              {%- if product.selected_or_first_available_variant.available -%}{{ 'products.product.add_to_cart' | t }}{%- else -%}{{ 'products.product.sold_out' | t }}{%- endif -%}
            </button>
          </div>
          <script type="application/json" data-variant-json>{{ product.variants | json }}</script>
        {% endform %}

        <div class="product-info__trust">
          <div class="product-info__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Free delivery across Pakistan
          </div>
          <div class="product-info__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            2-year warranty included
          </div>
          <div class="product-info__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            30-day hassle-free returns
          </div>
          <div class="product-info__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Personal styling support
          </div>
        </div>

        {%- if section.settings.show_accordion -%}
          <div class="accordion">
            {%- if section.settings.details != blank -%}
              <div class="accordion-item is-open">
                <button class="accordion-trigger" type="button">{{ 'products.product.details' | t }}{% render 'icon-chevron' %}</button>
                <div class="accordion-content"><div class="accordion-content__inner">{{ section.settings.details }}</div></div>
              </div>
            {%- endif -%}
            {%- if section.settings.shipping != blank -%}
              <div class="accordion-item">
                <button class="accordion-trigger" type="button">{{ 'products.product.shipping' | t }}{% render 'icon-chevron' %}</button>
                <div class="accordion-content"><div class="accordion-content__inner">{{ section.settings.shipping }}</div></div>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-gallery-thumb]').forEach(thumb => {
    thumb.addEventListener('click', () => {
      const main = document.getElementById('ProductGallery-Featured');
      if (main) main.src = thumb.dataset.galleryThumb;
      document.querySelectorAll('.product-gallery__thumb').forEach(t => t.classList.remove('is-active'));
      thumb.classList.add('is-active');
    });
  });
</script>

{% schema %}
{
  "name": "Product information",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "show_accordion", "label": "Show details accordion", "default": true },
    { "type": "richtext", "id": "details", "label": "Product details", "default": "<p>Handcrafted Italian acetate frame with premium CR-39 lenses offering 100% UV protection. Spring hinge temples for superior comfort. Includes premium hard case, microfiber cloth, and certificate of authenticity.</p>" },
    { "type": "richtext", "id": "shipping", "label": "Shipping & returns", "default": "<p>Complimentary white-glove delivery across Pakistan within 2-4 business days. 30-day hassle-free returns with full refund. All frames include a 2-year manufacturer warranty.</p>" }
  ]
}
{% endschema %}
