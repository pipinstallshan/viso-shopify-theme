<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    transition: background 0.5s ease, border-color 0.5s ease, backdrop-filter 0.5s ease;
    border-bottom: 1px solid transparent;
  }

  .header.is-transparent {
    background: transparent;
    border-color: transparent;
  }

  .header.is-scrolled,
  .header:not(.is-transparent) {
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(16px);
    border-color: var(--color-border);
  }

  .template-index .main-content {
    padding-top: 0;
  }

  body:not(.template-index) .main-content {
    padding-top: var(--header-height);
  }

  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 1.5rem var(--page-gutter);
    max-width: var(--page-width);
    margin: 0 auto;
    min-height: var(--header-height);
  }

  .header__left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .header__logo {
    justify-self: center;
  }

  .header__logo-text {
    font-family: var(--font-heading);
    font-size: 2rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    font-weight: 400;
  }

  .header__logo img {
    width: {{ settings.logo_width }}px;
    height: auto;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 2.75rem;
  }

  .header__nav-link {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    position: relative;
    padding: 0.25rem 0;
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-gold);
    transform: scaleX(0);
    transition: transform var(--transition);
  }

  .header__nav-link:hover::after { transform: scaleX(1); }

  .header__icons {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-text);
    transition: color var(--transition);
    position: relative;
  }

  .header__icon:hover { color: var(--color-gold); }

  .header__cart-count {
    position: absolute;
    top: 6px;
    right: 6px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background: var(--color-gold);
    color: var(--color-background);
    font-size: 0.5625rem;
    font-weight: 600;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    max-width: 420px;
    height: 100%;
    background: var(--color-background);
    z-index: 999;
    transform: translateX(-100%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 2.5rem var(--page-gutter);
    overflow-y: auto;
    border-right: 1px solid var(--color-border);
  }

  .mobile-menu.is-active { transform: translateX(0); }

  .mobile-menu__link {
    display: block;
    padding: 1.25rem 0;
    font-family: var(--font-heading);
    font-size: 1.75rem;
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition);
  }

  .mobile-menu__link:hover { color: var(--color-gold); }

  @media (max-width: 989px) {
    .header__inner { grid-template-columns: auto 1fr auto; }
    .header__nav { display: none; }
    .header__logo { justify-self: start; margin-left: 1rem; }
  }

  @media (min-width: 990px) {
    .header__menu-toggle { display: none; }
  }
</style>

<header class="header{% if template.name == 'index' %} is-transparent{% endif %}" data-header role="banner">
  <div class="header__inner">
    <div class="header__left">
      <button class="header__icon header__menu-toggle" data-mobile-menu-toggle aria-label="{{ 'general.accessibility.menu' | t }}">
        {% render 'icon-menu' %}
      </button>
      <nav class="header__nav" role="navigation">
        {%- for link in linklists[section.settings.menu].links limit: 4 -%}
          <a href="{{ link.url }}" class="header__nav-link">{{ link.title }}</a>
        {%- endfor -%}
      </nav>
    </div>

    <a href="/" class="header__logo">
      {%- if settings.logo != blank -%}
        {{ settings.logo | image_url: width: 400 | image_tag: alt: shop.name, loading: 'eager' }}
      {%- else -%}
        <span class="header__logo-text">Viso</span>
      {%- endif -%}
    </a>

    <div class="header__icons">
      <button class="header__icon" data-search-toggle aria-label="{{ 'general.accessibility.search' | t }}">
        {% render 'icon-search' %}
      </button>
      <a href="/account" class="header__icon hide-mobile" aria-label="{{ 'customer.account.title' | t }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      {%- if settings.cart_type == 'drawer' -%}
        <button class="header__icon" data-cart-toggle aria-label="{{ 'general.accessibility.cart' | t }}">
          {% render 'icon-cart' %}
          {%- if cart.item_count > 0 -%}
            <span class="header__cart-count">{{ cart.item_count }}</span>
          {%- endif -%}
        </button>
      {%- else -%}
        <a href="/cart" class="header__icon" aria-label="{{ 'general.accessibility.cart' | t }}">
          {% render 'icon-cart' %}
          {%- if cart.item_count > 0 -%}
            <span class="header__cart-count">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      {%- endif -%}
    </div>
  </div>
</header>

<div class="overlay" data-mobile-menu-overlay></div>
<nav class="mobile-menu" data-mobile-menu aria-label="Mobile navigation">
  <button class="modal__close" data-mobile-menu-close aria-label="{{ 'general.accessibility.close' | t }}" style="margin-bottom: 2.5rem;">
    {% render 'icon-close' %}
  </button>
  {%- for link in linklists[section.settings.menu].links -%}
    <a href="{{ link.url }}" class="mobile-menu__link">{{ link.title }}</a>
  {%- endfor -%}
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
