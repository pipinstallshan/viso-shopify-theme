<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 200;
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(14px);
  }

  .header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: center;
    min-height: var(--header-height);
    padding-block: 0.8rem;
  }

  .header__logo-text {
    font-family: var(--font-heading);
    color: #111;
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.08em;
    text-transform: lowercase;
  }

  .header__logo img {
    width: {{ settings.logo_width }}px;
    height: auto;
  }

  .header__nav {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .header__nav-link {
    color: #111;
    font-size: 0.86rem;
    font-weight: 850;
  }

  .header__nav-link:hover {
    color: var(--color-gold);
  }

  .header__icons {
    display: flex;
    align-items: center;
    justify-content: end;
    gap: 0.35rem;
  }

  .header__icon {
    position: relative;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    color: #111;
    transition: background var(--transition);
  }

  .header__icon:hover {
    background: var(--color-surface);
  }

  .header__cart-count {
    position: absolute;
    top: 3px;
    right: 2px;
    display: grid;
    place-items: center;
    min-width: 17px;
    height: 17px;
    padding: 0 4px;
    border-radius: 999px;
    color: #111;
    background: var(--color-gold);
    font-size: 0.62rem;
    font-weight: 900;
  }

  .mobile-menu {
    position: fixed;
    inset: 0 auto 0 0;
    z-index: 999;
    width: min(88vw, 420px);
    padding: 2rem var(--page-gutter);
    background: #fff;
    transform: translateX(-100%);
    transition: transform var(--transition);
    box-shadow: 24px 0 80px rgba(0, 0, 0, 0.12);
  }

  .mobile-menu.is-active { transform: translateX(0); }

  .mobile-menu__link {
    display: block;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
    color: #111;
    font-size: 1.35rem;
    font-weight: 900;
  }

  @media (max-width: 989px) {
    .header__inner { grid-template-columns: auto auto 1fr; }
    .header__nav { display: none; }
  }

  @media (min-width: 990px) {
    .header__menu-toggle { display: none; }
  }
</style>

<header class="header" data-header role="banner">
  <div class="page-width header__inner">
    <button class="header__icon header__menu-toggle" data-mobile-menu-toggle aria-label="{{ 'general.accessibility.menu' | t }}">
      {% render 'icon-menu' %}
    </button>

    <a href="/" class="header__logo">
      {%- if settings.logo != blank -%}
        {{ settings.logo | image_url: width: 400 | image_tag: alt: shop.name, loading: 'eager' }}
      {%- else -%}
        <span class="header__logo-text">viso</span>
      {%- endif -%}
    </a>

    <nav class="header__nav" role="navigation">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}" class="header__nav-link">{{ link.title }}</a>
      {%- else -%}
        <a href="/collections/all" class="header__nav-link">Best Sellers</a>
        <a href="/collections/all" class="header__nav-link">New Arrivals</a>
        <a href="/pages/about" class="header__nav-link">Our Story</a>
        <a href="/pages/faq" class="header__nav-link">Refund Policy</a>
      {%- endfor -%}
    </nav>

    <div class="header__icons">
      <button class="header__icon" data-search-toggle aria-label="{{ 'general.accessibility.search' | t }}">
        {% render 'icon-search' %}
      </button>
      <a href="/account" class="header__icon hide-mobile" aria-label="{{ 'customer.account.title' | t }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      {%- if settings.cart_type == 'drawer' -%}
        <button class="header__icon" data-cart-toggle aria-label="{{ 'general.accessibility.cart' | t }}">
          {% render 'icon-cart' %}
          {%- if cart.item_count > 0 -%}<span class="header__cart-count">{{ cart.item_count }}</span>{%- endif -%}
        </button>
      {%- else -%}
        <a href="/cart" class="header__icon" aria-label="{{ 'general.accessibility.cart' | t }}">
          {% render 'icon-cart' %}
          {%- if cart.item_count > 0 -%}<span class="header__cart-count">{{ cart.item_count }}</span>{%- endif -%}
        </a>
      {%- endif -%}
    </div>
  </div>
</header>

<div class="overlay" data-mobile-menu-overlay></div>
<nav class="mobile-menu" data-mobile-menu aria-label="Mobile navigation">
  <button class="modal__close" data-mobile-menu-close aria-label="{{ 'general.accessibility.close' | t }}">
    {% render 'icon-close' %}
  </button>
  {%- for link in linklists[section.settings.menu].links -%}
    <a href="{{ link.url }}" class="mobile-menu__link">{{ link.title }}</a>
  {%- else -%}
    <a href="/collections/all" class="mobile-menu__link">Best Sellers</a>
    <a href="/collections/all" class="mobile-menu__link">New Arrivals</a>
    <a href="/pages/about" class="mobile-menu__link">Our Story</a>
    <a href="/pages/faq" class="mobile-menu__link">Refund Policy</a>
  {%- endfor -%}
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
