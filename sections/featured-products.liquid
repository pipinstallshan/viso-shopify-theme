<style>
  .featured-products {
    padding: var(--section-spacing) 0;
  }

  .featured-products__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem 1.5rem;
  }

  @media (max-width: 989px) {
    .featured-products__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<section class="featured-products">
  <div class="page-width">
    <div class="section-header section-header--split animate-on-scroll">
      <div>
        <span class="eyebrow eyebrow--line">{{ section.settings.eyebrow }}</span>
        <h2 class="section-header__title">{{ section.settings.title }}</h2>
        {%- if section.settings.text != blank -%}
          <p class="section-header__text" style="margin-top:1rem;">{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn--outline-gold btn-arrow">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>

    <div class="featured-products__grid stagger-children">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection != blank -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <div class="animate-on-scroll">
            {% render 'product-card', card_product: product %}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="product-card animate-on-scroll">
            <div class="product-card__media luxury-frame">
              <div class="placeholder-image">Frame {{ i }}</div>
              <span class="product-card__badge">New Arrival</span>
            </div>
            <div class="product-card__info">
              <p class="product-card__vendor">Viso Atelier</p>
              <h3 class="product-card__title">Signature No. {{ i }}</h3>
              <p class="product-card__price">Rs. {% case i %}{% when 1 %}47,500{% when 2 %}52,000{% when 3 %}38,500{% else %}61,000{% endcase %}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bestsellers" },
    { "type": "text", "id": "title", "label": "Heading", "default": "The Edit" },
    { "type": "textarea", "id": "text", "label": "Description", "default": "Our most coveted frames, chosen by those who demand nothing less than exceptional." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "text", "id": "button_label", "label": "Button", "default": "View All" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
