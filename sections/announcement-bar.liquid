{%- if section.settings.text != blank -%}
<div class="announcement-bar" style="background: var(--color-accent); text-align: center; padding: 0.625rem var(--page-gutter); font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
  {%- else -%}
    <span>{{ section.settings.text }}</span>
  {%- endif -%}
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Complimentary white-glove delivery across Pakistan"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ]
}
{% endschema %}
