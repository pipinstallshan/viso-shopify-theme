<style>
  .cart-page {
    padding: clamp(2.5rem, 6vw, 5rem) 0 var(--section-spacing);
    background: #fff;
  }

  .cart-page__header {
    max-width: 760px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .cart-page__title {
    margin-bottom: 0.7rem;
    font-size: clamp(2.5rem, 6vw, 5rem);
  }

  .cart-page__subtitle {
    color: var(--color-text-muted);
    font-weight: 750;
  }

  .cart-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(330px, 420px);
    gap: 2rem;
    align-items: start;
  }

  .cart-panel,
  .cart-summary {
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 26px;
    background: #fff;
    box-shadow: 0 18px 48px rgba(17, 17, 17, 0.07);
  }

  .cart-panel {
    overflow: hidden;
  }

  .cart-panel__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 120px 150px 120px 70px;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .cart-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 120px 150px 120px 70px;
    gap: 1rem;
    align-items: center;
    padding: 1.25rem;
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
  }

  .cart-item:last-child {
    border-bottom: 0;
  }

  .cart-item__product {
    display: grid;
    grid-template-columns: 104px minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    min-width: 0;
  }

  .cart-item__image-wrap {
    overflow: hidden;
    width: 104px;
    height: 104px;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 18px;
    background: var(--color-surface);
  }

  .cart-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item__title {
    display: inline-block;
    margin-bottom: 0.4rem;
    color: #111;
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.35;
  }

  .cart-item__variant,
  .cart-item__mobile-meta {
    color: var(--color-text-muted);
    font-size: 0.84rem;
    font-weight: 750;
  }

  .cart-item__price,
  .cart-item__total {
    color: #111;
    font-weight: 900;
    white-space: nowrap;
  }

  .cart-item__total {
    color: var(--color-gold);
  }

  .cart-item__remove {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    font-weight: 900;
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  .cart-notes {
    margin-top: 1.25rem;
  }

  .cart-notes .form-textarea {
    min-height: 116px;
  }

  .cart-summary {
    position: sticky;
    top: calc(var(--header-height) + 1.5rem);
    padding: 1.5rem;
    background: var(--color-surface);
  }

  .cart-summary__title {
    margin-bottom: 1.25rem;
    color: #111;
    font-size: 1.45rem;
  }

  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
    color: #111;
    font-weight: 850;
  }

  .cart-summary__muted {
    margin-bottom: 1.2rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .cart-summary__total {
    padding-top: 1rem;
    border-top: 1px solid rgba(17, 17, 17, 0.1);
    font-size: 1.15rem;
  }

  .cart-summary__trust {
    display: grid;
    gap: 0.55rem;
    margin-top: 1.25rem;
    color: var(--color-text-muted);
    font-size: 0.84rem;
    font-weight: 750;
  }

  .cart-empty {
    max-width: 560px;
    margin: 0 auto;
    padding: 4rem 2rem;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 28px;
    background: var(--color-surface);
    text-align: center;
  }

  @media (max-width: 1100px) {
    .cart-layout {
      grid-template-columns: 1fr;
    }

    .cart-summary {
      position: static;
    }
  }

  @media (max-width: 820px) {
    .cart-panel__head {
      display: none;
    }

    .cart-item {
      grid-template-columns: 1fr;
      gap: 1rem;
      align-items: start;
    }

    .cart-item__product {
      grid-template-columns: 90px minmax(0, 1fr);
    }

    .cart-item__image-wrap {
      width: 90px;
      height: 90px;
    }

    .cart-item__price {
      display: none;
    }

    .cart-item__quantity,
    .cart-item__total,
    .cart-item__remove-cell {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .cart-item__quantity::before {
      content: 'Quantity';
      color: var(--color-text-muted);
      font-size: 0.8rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .cart-item__total::before {
      content: 'Total';
      color: var(--color-text-muted);
      font-size: 0.8rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
  }
</style>

<section class="cart-page">
  <div class="page-width">
    <div class="cart-page__header">
      <span class="eyebrow">{{ 'cart.general.title' | t }}</span>
      <h1 class="cart-page__title">Your Selection</h1>
      <p class="cart-page__subtitle">{{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %} reserved for checkout</p>
    </div>

    {%- if cart.item_count > 0 -%}
      <form action="/cart" method="post" id="CartForm">
        <div class="cart-layout">
          <div>
            <div class="cart-panel">
              <div class="cart-panel__head">
                <span>Product</span>
                <span>Price</span>
                <span>Quantity</span>
                <span>Total</span>
                <span></span>
              </div>

              {%- for item in cart.items -%}
                <div class="cart-item">
                  <div class="cart-item__product">
                    <a href="{{ item.url }}" class="cart-item__image-wrap">
                      {%- if item.image -%}
                        <img src="{{ item.image | image_url: width: 220 }}" alt="{{ item.title | escape }}" class="cart-item__image" loading="lazy">
                      {%- else -%}
                        <div class="placeholder-image" style="min-height: 100%; font-size: 0.55rem;">Viso</div>
                      {%- endif -%}
                    </a>
                    <div style="min-width: 0;">
                      <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                      {%- unless item.product.has_only_default_variant -%}
                        <p class="cart-item__variant">{{ item.variant.title }}</p>
                      {%- endunless -%}
                      <p class="cart-item__mobile-meta show-mobile">{{ item.original_price | money }}</p>
                    </div>
                  </div>

                  <div class="cart-item__price">{{ item.original_price | money }}</div>

                  <div class="cart-item__quantity">
                    <div class="quantity-selector">
                      <button type="button" data-quantity-minus aria-label="Decrease quantity">−</button>
                      <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" data-index="{{ forloop.index }}" aria-label="Quantity for {{ item.product.title | escape }}">
                      <button type="button" data-quantity-plus aria-label="Increase quantity">+</button>
                    </div>
                  </div>

                  <div class="cart-item__total">{{ item.final_line_price | money }}</div>

                  <div class="cart-item__remove-cell">
                    <a href="{{ item.url_to_remove }}" class="cart-item__remove">{{ 'cart.general.remove' | t }}</a>
                  </div>
                </div>
              {%- endfor -%}
            </div>

            {%- if settings.cart_show_note -%}
              <div class="cart-notes form-field">
                <label for="CartNote">{{ 'cart.general.note' | t }}</label>
                <textarea id="CartNote" name="note" class="form-textarea" placeholder="{{ 'cart.general.note_placeholder' | t }}">{{ cart.note }}</textarea>
              </div>
            {%- endif -%}
          </div>

          <aside class="cart-summary" aria-label="Order summary">
            <h2 class="cart-summary__title">Order Summary</h2>
            <div class="cart-summary__row">
              <span>{{ 'cart.general.subtotal' | t }}</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <p class="cart-summary__muted">{{ 'cart.general.shipping_note' | t }}</p>
            <div class="cart-summary__row cart-summary__total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <button type="submit" name="checkout" class="btn btn--primary btn--full">{{ 'cart.general.checkout' | t }}</button>
            <a href="/collections/all" class="btn btn--secondary btn--full" style="margin-top: 0.75rem;">{{ 'cart.general.continue_shopping' | t }}</a>
            <div class="cart-summary__trust">
              <span>✓ Secure checkout</span>
              <span>✓ 30 days money back</span>
              <span>✓ Fast delivery across Pakistan</span>
            </div>
          </aside>
        </div>
      </form>
    {%- else -%}
      <div class="cart-empty">
        <h2 style="margin-bottom: 0.75rem;">{{ 'cart.general.empty' | t }}</h2>
        <p class="text-muted" style="margin-bottom: 1.5rem;">Your next favourite pair is waiting.</p>
        <a href="/collections/all" class="btn btn--primary">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section"
}
{% endschema %}
