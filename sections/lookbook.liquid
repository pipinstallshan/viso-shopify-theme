<style>
  .lookbook {
    padding: var(--section-spacing) 0;
    overflow: hidden;
  }

  .lookbook__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .lookbook__nav {
    display: flex;
    gap: 0.75rem;
  }

  .lookbook__nav button {
    width: 52px;
    height: 52px;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    transition: all var(--transition);
  }

  .lookbook__nav button:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .lookbook__viewport {
    overflow: hidden;
    margin-right: calc(-1 * var(--page-gutter));
  }

  .lookbook__track {
    display: flex;
    gap: 1.5rem;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    padding-right: var(--page-gutter);
  }

  .lookbook__item {
    flex: 0 0 clamp(280px, 32vw, 420px);
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/4;
  }

  .lookbook__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lookbook__item:hover img {
    transform: scale(1.06);
  }

  .lookbook__item-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.85) 0%, transparent 50%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .lookbook__item:hover .lookbook__item-overlay {
    opacity: 1;
  }

  .lookbook__item-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .lookbook__item-sub {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
  }
</style>

<section class="lookbook" data-lookbook>
  <div class="page-width">
    <div class="lookbook__header animate-on-scroll">
      <div>
        <span class="eyebrow eyebrow--line">{{ section.settings.eyebrow }}</span>
        <h2 class="section-header__title">{{ section.settings.title }}</h2>
      </div>
      <div class="lookbook__nav">
        <button type="button" data-lookbook-prev aria-label="Previous">←</button>
        <button type="button" data-lookbook-next aria-label="Next">→</button>
      </div>
    </div>
  </div>

  <div class="lookbook__viewport page-width">
    <div class="lookbook__track" data-lookbook-track>
      {%- for block in section.blocks -%}
        <div class="lookbook__item animate-on-scroll" data-lookbook-item {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 840 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {%- else -%}
            <div class="placeholder-image" style="height:100%;">Editorial {{ forloop.index }}</div>
          {%- endif -%}
          <div class="lookbook__item-overlay">
            <p class="lookbook__item-sub">{{ block.settings.subtitle }}</p>
            <h3 class="lookbook__item-title">{{ block.settings.title }}</h3>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lookbook",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Editorial"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Viso Lookbook"
    }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Midnight Aviator" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "SS26 Collection" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook",
      "blocks": [
        { "type": "look", "settings": { "title": "Midnight Aviator", "subtitle": "SS26 Collection" } },
        { "type": "look", "settings": { "title": "Emerald Cat Eye", "subtitle": "Signature Series" } },
        { "type": "look", "settings": { "title": "Gold Temple", "subtitle": "Limited Edition" } },
        { "type": "look", "settings": { "title": "Polarised Classic", "subtitle": "Essentials" } },
        { "type": "look", "settings": { "title": "Tortoise Oversized", "subtitle": "Heritage Line" } }
      ]
    }
  ]
}
{% endschema %}
