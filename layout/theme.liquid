<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_background }}">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  {{ content_for_header }}

  {%- liquid
    assign heading_font = settings.font_heading
    assign body_font = settings.font_body
  -%}

  {% style %}
    {{ heading_font | font_face: font_display: 'swap' }}
    {{ body_font | font_face: font_display: 'swap' }}

    :root {
      --color-background: {{ settings.color_background }};
      --color-surface: {{ settings.color_surface }};
      --color-text: {{ settings.color_text }};
      --color-text-muted: {{ settings.color_text_muted }};
      --color-accent: {{ settings.color_accent }};
      --color-gold: {{ settings.color_gold }};
      --color-border: {{ settings.color_border }};
      --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
      --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
      --font-size-base: {{ settings.font_size_base }}px;
      --font-heading-weight: {{ heading_font.weight }};
      --font-body-weight: {{ body_font.weight }};
      --font-heading-style: {{ heading_font.style }};
      --font-body-style: {{ body_font.style }};
      --page-width: 1440px;
      --page-gutter: clamp(1.5rem, 5vw, 4rem);
      --section-spacing: clamp(5rem, 10vw, 9rem);
      --transition: 0.45s cubic-bezier(0.16, 1, 0.3, 1);
      --header-height: 80px;
    }
  {% endstyle %}

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'components.css' | asset_url | stylesheet_tag }}

  <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
  <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
</head>

<body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.name | handle }}-{{ template.suffix }}{% endif %}">
  <a class="skip-link visually-hidden" href="#MainContent">{{ 'general.accessibility.skip_to_content' | t }}</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {%- if settings.cart_type == 'drawer' -%}
    {% render 'cart-drawer' %}
  {%- endif -%}

  {% render 'search-modal' %}
</body>
</html>
