<div class="overlay" data-cart-overlay></div>

<aside class="drawer" data-cart-drawer aria-label="{{ 'cart.general.title' | t }}">
  <div class="drawer__header">
    <h2 class="drawer__title">{{ 'cart.general.title' | t }}</h2>
    <button class="modal__close" data-cart-close aria-label="{{ 'general.accessibility.close' | t }}">
      {% render 'icon-close' %}
    </button>
  </div>

  <div class="drawer__body" id="CartDrawer-Body">
    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__items">
        {%- for item in cart.items -%}
          <div class="cart-drawer__item" style="display: flex; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
            <a href="{{ item.url }}" style="flex-shrink: 0; width: 80px;">
              {%- if item.image -%}
                {{ item.image | image_url: width: 160 | image_tag: loading: 'lazy', alt: item.title }}
              {%- else -%}
                <div class="placeholder-image" style="width: 80px; aspect-ratio: 1;">Viso</div>
              {%- endif -%}
            </a>
            <div style="flex: 1;">
              <a href="{{ item.url }}" style="font-family: var(--font-heading); font-size: 1rem;">{{ item.product.title }}</a>
              {%- unless item.product.has_only_default_variant -%}
                <p class="text-muted" style="font-size: 0.8125rem; margin-top: 0.25rem;">{{ item.variant.title }}</p>
              {%- endunless -%}
              <p style="margin-top: 0.5rem; color: var(--color-gold);">{{ item.final_line_price | money }}</p>
              <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.75rem;">
                <div class="quantity-selector">
                  <button data-quantity-minus aria-label="Decrease quantity">−</button>
                  <input type="number" value="{{ item.quantity }}" min="0" aria-label="Quantity">
                  <button data-quantity-plus aria-label="Increase quantity">+</button>
                </div>
                <a href="{{ item.url_to_remove }}" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-muted);">{{ 'cart.general.remove' | t }}</a>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="cart-drawer__empty" style="text-align: center; padding: 3rem 0;">
        <p class="text-muted" style="margin-bottom: 2rem;">{{ 'cart.general.empty' | t }}</p>
        <a href="/collections/all" class="btn btn--outline-gold">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    {%- endif -%}
  </div>

  {%- if cart.item_count > 0 -%}
    <div class="drawer__footer">
      <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
        <span class="text-muted">{{ 'cart.general.subtotal' | t }}</span>
        <span style="font-size: 1.125rem;">{{ cart.total_price | money }}</span>
      </div>
      <p class="text-muted" style="font-size: 0.8125rem; margin-bottom: 1.5rem;">{{ 'cart.general.shipping_note' | t }}</p>
      <a href="/checkout" class="btn btn--primary btn--full">{{ 'cart.general.checkout' | t }}</a>
      <a href="/cart" class="btn btn--secondary btn--full" style="margin-top: 0.75rem;">View Cart</a>
    </div>
  {%- endif -%}
</aside>

<style>
  .cart-drawer__item img {
    width: 80px;
    height: 80px;
    object-fit: cover;
  }
</style>
